# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub

RESEND_API_KEY=re_your_api_key_here
QUOTE_RECIPIENT_EMAIL=your@email.com
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- B2B outreach campaign system (scripts/send-campaign.js) ---
# From address for outreach (use a verified domain in Resend, e.g. hello@tomahawkjunkremoval.com).
# Falls back to RESEND_FROM_EMAIL if unset.
OUTREACH_FROM_EMAIL=hello@tomahawkjunkremoval.com
# Where replies should go (defaults to BUSINESS_EMAIL below).
OUTREACH_REPLY_TO=tomahawkjunkremoval@gmail.com
# Optional: BCC yourself on every outreach email for your records.
# OUTREACH_BCC=you@example.com

# Business identity used in email footers and the unsubscribe page.
BUSINESS_NAME=Tomahawk Junk Removal LLC
# REQUIRED for live sends — a valid physical postal address (CAN-SPAM law).
BUSINESS_ADDRESS=123 Main St, Marietta, GA 30060
BUSINESS_PHONE=(404) 771-7677
BUSINESS_EMAIL=tomahawkjunkremoval@gmail.com

# Public site URL — used to build unsubscribe links (no trailing slash).
SITE_URL=https://tomahawkjunkremoval.com
# Optional but recommended: signs unsubscribe links so they can't be forged.
UNSUBSCRIBE_SECRET=change_me_to_a_long_random_string

# --- Automated lead discovery (scripts/find-leads.js) ---
# Google Cloud API key with the "Places API (New)" enabled. Has a free monthly
# credit. Used to find target businesses by type and area.
GOOGLE_PLACES_API_KEY=

# --- Connect the live unsubscribe page to the automated pipeline (optional) ---
# Lets the website's /api/unsubscribe route record opt-outs into the scheduled
# GitHub Actions pipeline. Set these in your Vercel project env, not just here.
# A fine-grained PAT with "Contents: read/write" on this repo is enough.
OUTREACH_GH_TOKEN=
OUTREACH_GH_REPO=Swilson52/Tomahawk_Junk_Removal
